<Window x:Class="AutoOpener.Configurator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoOpener.Configurator"
        mc:Ignorable="d"
        Title="AutoOpener Configurator" Height="450" Width="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Profile name:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox x:Name="tbName" Grid.Row="0" Margin="140,0,0,0" Width="360" HorizontalAlignment="Left" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Revit version:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox x:Name="cbVersion" Grid.Row="1" Margin="140,0,0,0" Width="120" HorizontalAlignment="Left" VerticalContentAlignment="Center">
            <ComboBoxItem Content="2022"/>
            <ComboBoxItem Content="2023"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Text="Model path (RSN://... or .rvt):" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="140,0,0,8">
            <TextBox x:Name="tbModel" Width="360" VerticalContentAlignment="Center"/>
            <Button Content="Browse..." Width="80" Margin="8,0,0,0" Click="OnBrowse"/>
            <Button Content="Build RSN..." Width="100" Margin="8,0,0,0" Click="OnBuildRsn"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Add Workset:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="140,0,0,8">
            <TextBox x:Name="tbNewWorkset" Width="270" VerticalContentAlignment="Center" KeyDown="OnNewWorksetKeyDown"/>
            <Button Content="Add" Width="82" Margin="8,0,0,0" Click="OnAddWorkset"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Worksets to open:" VerticalAlignment="Top" Margin="0,0,0,0"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="140,0,0,0">
            <ListBox x:Name="lbWorksets" Width="270" MinHeight="100"/>
            <Button Content="Remove" Width="82" Margin="8,0,0,0" VerticalAlignment="Top" Click="OnRemoveWorkset"/>
        </StackPanel>

        <TextBlock Grid.Row="5" TextWrapping="Wrap" Margin="0,16,0,16" Foreground="DarkGray">
          Укажите RSN://host/... для Revit Server или укажите локальный/сетевой .rvt.
          При сохранении профиля хост RSN будет добавлен в RSN.ini при необходимости.
        </TextBlock>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save profile" Width="120" Margin="0,0,8,0" Click="OnSaveProfile"/>
            <Button Content="Ensure RSN host" Width="140" Margin="0,0,8,0" Click="OnEnsureRsn"/>
            <Button Content="Close" Width="80" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>